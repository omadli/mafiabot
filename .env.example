# ============================================
# Mafia Telegram Bot — Environment Variables
# ============================================
# Production / Docker uchun. Local dev uchun .env.local.example ni ko'ring.
#
# Copy to .env and fill in real values

# === Domain ===
PUBLIC_DOMAIN=mafia.omadli.uz

# === Telegram Bot ===
BOT_TOKEN=
BOT_USERNAME=MafGameUzBot
WEBHOOK_SECRET=change_me_to_random_string
WEBHOOK_BASE_URL=https://mafia.omadli.uz

# === Bot run mode ===
# Production: webhook (FastAPI orqali update qabul qilish)
# Local dev:  polling (uzoq polling, webhook'siz)
BOT_MODE=webhook

# === FSM storage ===
# redis: production (Redis bilan)
# memory: local dev (RAM, restart'da yo'qoladi)
FSM_STORAGE=redis

# === Database ===
# DATABASE_URL ko'rsatilgan bo'lsa POSTGRES_* o'rniga ishlatiladi.
# Production: DATABASE_URL bo'sh, POSTGRES_* ishlatiladi.
# Local dev:  DATABASE_URL=sqlite://./mafia.db
DATABASE_URL=

POSTGRES_USER=mafia
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=mafia
POSTGRES_HOST=postgres
POSTGRES_PORT=5433

# === Redis ===
REDIS_HOST=redis
REDIS_PORT=6380
REDIS_DB=0

# === Backend ===
BACKEND_PORT=8001
SECRET_KEY=change_me_to_random_secret
DEBUG=false
ENVIRONMENT=production

# === Super admin (default) ===
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=change_me_admin_password

# === Sentry (optional, leave empty to disable) ===
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# === Backup ===
BACKUP_RETENTION_DAYS=7

# === Frontend deploy ===
FRONTEND_DOCROOT=/var/www/mafia
