# ============================================
# LOCAL DEV — Docker'siz, SQLite + Memory + Polling
# ============================================
# Copy to .env.local. Ushbu fayl .env'dan keyin yuklanadi va override qiladi.

# === Telegram bot ===
# @BotFather'dan oling
BOT_TOKEN=
BOT_USERNAME=MafGameUzBot

# === Mode flags (local dev) ===
BOT_MODE=polling           # webhook'siz, long polling
FSM_STORAGE=memory         # Redis kerak emas, RAM da
DATABASE_URL=sqlite://./mafia.db  # PostgreSQL kerak emas

# === Backend ===
BACKEND_PORT=8001
SECRET_KEY=dev-secret-not-for-production
DEBUG=true
ENVIRONMENT=development

# === Super admin (lokal test uchun) ===
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=admin

# === Super admin via Telegram (in-bot /sa_* commands) ===
# Telegram user IDs vergul bilan. Kim botdan @userinfobot orqali ID olishi mumkin.
# Misol: SUPER_ADMIN_TELEGRAM_IDS=123456789,987654321
SUPER_ADMIN_TELEGRAM_IDS=
